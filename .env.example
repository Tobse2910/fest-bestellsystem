# ============================================================================
#  Fest-Bestellsystem – Umgebungsvariablen
#
#  ERSTE EINRICHTUNG:  diese Datei nach  .env  kopieren und Werte eintragen:
#      cp .env.example .env
#
#  Die echte .env ist per .gitignore vom Repo ausgeschlossen und wird zusätzlich
#  per .htaccess vor dem Aufruf im Browser geschützt – Geheimnisse bleiben geheim.
#  Ohne .env läuft die App im Demo-Modus (Passwörter = changeme, SQLite).
# ============================================================================

# --- Passwörter je Rolle · VOR DEM EINSATZ UNBEDINGT ÄNDERN! ---
KASSE_PASSWORT=changeme
BAR_PASSWORT=changeme
ADMIN_PASSWORT=changeme

# --- Name des Fests (Fallback; im Admin-Bereich überschreibbar) ---
FEST_NAME=Straßenfest

# --- Datenbank (MySQL, Live-Webspace). Leer lassen = automatisch SQLite (Demo/lokal). ---
DB_HOST=
DB_NAME=
DB_USER=
DB_PASS=
